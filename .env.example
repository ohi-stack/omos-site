# OMOS.OneGodian.com Node Runtime
NODE_ENV=production
PORT=3000
OMOS_VERSION=0.3.0

# Canonical URLs
OMOS_CANONICAL_HOST=https://omos.onegodian.com
OMOS_PUBLIC_URL=https://omos.onegodian.com
ONEGODIAN_PUBLIC_URL=https://onegodian.org
ONEGODIAN_COMMERCE_URL=https://onegodian.com
ONEGODIAN_STORE_URL=https://onegodian.com
ONEGODIAN_ORG_URL=https://onegodian.org
ONEGODIAN_APP_URL=https://app.onegodian.com
ONEGODIAN_CONSOLE_URL=https://console.onegodian.com

# Runtime access
# Use strong private values in production. Never commit live secrets.
OMOS_API_KEYS=replace-with-production-key

# Optional integrations
ACC_API_URL=
ACC_API_KEY=
QRV_VERIFY_URL=
OBP_NODE_URL=
STRIPE_PUBLISHABLE_KEY=

# Analytics / conversion tracking
OMOS_ANALYTICS_PROVIDER=ga4
OMOS_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
OMOS_CONVERSION_STORE_CATEGORY=/product-category/omos/

# Site metadata
SITE_NAME=OMOS — OneGodian Metaphysical Operating System
SITE_DESCRIPTION=Public node site and documentation layer for OMOS.OneGodian.com.
