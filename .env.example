# OMOS.OneGodian.com Node Runtime Environment
NODE_ENV=production
PORT=3000

# Versioning
OMOS_VERSION=0.3.0

# Canonical URLs
OMOS_CANONICAL_HOST=https://omos.onegodian.com
OMOS_PUBLIC_URL=https://omos.onegodian.com
ONEGODIAN_ORG_URL=https://onegodian.org
ONEGODIAN_PUBLIC_URL=https://onegodian.org
ONEGODIAN_STORE_URL=https://onegodian.com
ONEGODIAN_COMMERCE_URL=https://onegodian.com
ONEGODIAN_APP_URL=https://app.onegodian.com
ONEGODIAN_CONSOLE_URL=https://app.onegodian.com
ONEGODIAN_UNIVERSITY_URL=https://u.onegodian.com
ONEGODIAN_GALAXY_URL=https://galaxy.onegodian.com
ONEGODIAN_CAPITAL_URL=https://capital.onegodian.com
QUANTUMOHI_URL=https://quantumohi.com

# Runtime access
# Use strong private values in production. Never commit live secrets.
OMOS_API_KEYS=replace-with-production-key

# WordPress/plugin bridge targets
OMOS_WP_PLUGIN_SLUG=omos-core-tools
OMOS_WP_PLUGIN_VERSION=1.3.0
OMOS_BRIDGE_STATUS=planned
ONEGODIAN_ORG_PLUGIN_TARGET=true
ONEGODIAN_COM_PLUGIN_TARGET=true
QUANTUMOHI_PLUGIN_TARGET=true

# Optional integrations
ACC_API_URL=
ACC_API_KEY=
QRV_VERIFY_URL=
OBP_NODE_URL=
STRIPE_PUBLISHABLE_KEY=

# Analytics / conversion tracking
OMOS_ANALYTICS_PROVIDER=ga4
OMOS_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
OMOS_CONVERSION_STORE_CATEGORY=/product-category/omos/

# Compliance
# Gregorian/civil records remain controlling for legal, financial, and institutional purposes.
OMOS_LEGAL_DATE_AUTHORITY=Gregorian
SITE_NAME=OMOS — OneGodian Metaphysical Operating System
SITE_DESCRIPTION=Public node site and documentation layer for OMOS.OneGodian.com.
